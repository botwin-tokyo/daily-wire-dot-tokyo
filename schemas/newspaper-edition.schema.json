{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://themorningwire.example/schemas/newspaper-edition.schema.json",
  "title": "Botwin's Morning Wire — Newspaper Edition",
  "description": "Canonical JSON contract for a single AI-curated morning edition.",
  "type": "object",
  "required": [
    "schemaVersion",
    "editionId",
    "editionDate",
    "editionNumber",
    "status",
    "generatedAt",
    "updatedAt",
    "timezone",
    "locale",
    "masthead",
    "utilityBar",
    "navigation",
    "leadStoryId",
    "articles",
    "sections",
    "morningBriefing",
    "editorsNote",
    "marketSnapshot",
    "weather",
    "sources",
    "generationMetadata",
    "footer"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version in semver. Must match the validator's expected version."
    },
    "editionId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "editionDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "editionNumber": {
      "type": "integer",
      "minimum": 1
    },
    "editionTitle": {
      "type": "string",
      "maxLength": 100
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "published_with_warnings", "failed"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "locale": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "masthead": {
      "type": "object",
      "required": ["title", "tagline"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "maxLength": 100 },
        "tagline": { "type": "string", "maxLength": 200 }
      }
    },
    "utilityBar": {
      "type": "object",
      "required": ["dateLabel", "weather", "editionLabel", "updatedByAiAt", "nextEditionText"],
      "additionalProperties": false,
      "properties": {
        "dateLabel": { "type": "string", "maxLength": 100 },
        "weather": {
          "type": "object",
          "required": ["tempC", "condition", "icon"],
          "additionalProperties": false,
          "properties": {
            "tempC": { "type": "number" },
            "condition": { "type": "string", "maxLength": 50 },
            "icon": { "type": "string", "enum": ["sun", "cloud", "rain", "snow", "partly"] }
          }
        },
        "editionLabel": { "type": "string", "maxLength": 50 },
        "updatedByAiAt": { "type": "string", "maxLength": 20 },
        "nextEditionText": { "type": "string", "maxLength": 100 }
      }
    },
    "navigation": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/navItem" }
        },
        "moreLinks": {
          "type": "array",
          "items": { "$ref": "#/definitions/navItem" }
        }
      }
    },
    "leadStoryId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "articles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/article" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/section" }
    },
    "morningBriefing": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/definitions/briefingItem" }
    },
    "editorsNote": { "$ref": "#/definitions/editorsNote" },
    "marketSnapshot": { "$ref": "#/definitions/marketSnapshot" },
    "weather": { "$ref": "#/definitions/weatherSnapshot" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/definitions/transparencySource" }
    },
    "generationMetadata": { "$ref": "#/definitions/generationMetadata" },
    "footer": { "$ref": "#/definitions/footer" },
    "banners": {
      "type": "array",
      "items": { "$ref": "#/definitions/banner" }
    }
  },
  "definitions": {
    "navItem": {
      "type": "object",
      "required": ["id", "label", "path"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-zA-Z0-9_-]+$" },
        "label": { "type": "string", "maxLength": 30 },
        "path": { "type": "string", "pattern": "^/" },
        "category": {
          "oneOf": [
            { "type": "string", "enum": ["world", "technology", "business", "science", "culture"] },
            { "type": "null" }
          ]
        }
      }
    },
    "article": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "displayPosition",
        "headline",
        "summary",
        "category",
        "source",
        "originalUrl",
        "publishedAt",
        "retrievedAt",
        "readingTimeMin",
        "keyPoints",
        "relatedArticleIds",
        "relevanceScore",
        "confidenceScore",
        "editorialProminence",
        "aiDisclosure"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-zA-Z0-9_-]+$" },
        "slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "displayPosition": {
          "type": "string",
          "enum": ["lead", "major", "standard", "brief", "sidebar", "imageFeature"]
        },
        "headline": { "type": "string", "maxLength": 200 },
        "deck": { "type": "string", "maxLength": 300 },
        "summary": { "type": "string", "maxLength": 2000 },
        "category": {
          "type": "string",
          "enum": ["world", "technology", "business", "science", "culture"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 50 }
        },
        "author": { "type": "string", "maxLength": 100 },
        "source": { "$ref": "#/definitions/source" },
        "originalUrl": { "type": "string", "format": "uri" },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "readingTimeMin": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "keyPoints": {
          "type": "array",
          "items": { "type": "string", "maxLength": 300 }
        },
        "whyItMatters": { "type": "string", "maxLength": 1200 },
        "relatedArticleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9_-]+$"
          }
        },
        "relevanceScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "editorialProminence": { "type": "number", "minimum": 0, "maximum": 1 },
        "aiDisclosure": {
          "type": "object",
          "required": ["summaryIsAiGenerated"],
          "additionalProperties": false,
          "properties": {
            "summaryIsAiGenerated": { "type": "boolean" },
            "model": { "type": "string", "maxLength": 100 }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "url": { "type": "string", "format": "uri" },
        "reliability": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "image": {
      "type": "object",
      "required": ["url", "alt"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "string", "pattern": "^/" }
          ]
        },
        "alt": { "type": "string", "maxLength": 300 },
        "caption": { "type": "string", "maxLength": 500 },
        "attribution": { "type": "string", "maxLength": 200 }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "label", "eyebrow", "dek", "order", "visible", "articleIds"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": { "type": "string", "maxLength": 50 },
        "eyebrow": { "type": "string", "maxLength": 100 },
        "dek": { "type": "string", "maxLength": 300 },
        "order": { "type": "integer", "minimum": 0 },
        "visible": { "type": "boolean" },
        "articleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9_-]+$"
          }
        }
      }
    },
    "briefingItem": {
      "type": "object",
      "required": ["topic", "text", "sourceName"],
      "additionalProperties": false,
      "properties": {
        "topic": { "type": "string", "maxLength": 50 },
        "text": { "type": "string", "maxLength": 500 },
        "sourceName": { "type": "string", "maxLength": 100 },
        "articleId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "icon": { "type": "string", "enum": ["globe", "chart", "health", "tech", "culture"] }
      }
    },
    "editorsNote": {
      "type": "object",
      "required": ["text", "whyItMatters", "model", "generatedAt", "sourcesConsidered"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string", "maxLength": 2000 },
        "whyItMatters": { "type": "string", "maxLength": 1200 },
        "model": { "type": "string", "maxLength": 100 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "sourcesConsidered": { "type": "integer", "minimum": 0 }
      }
    },
    "marketSnapshot": {
      "type": "object",
      "required": ["updatedAt", "sourceName", "tickers", "commodities"],
      "additionalProperties": false,
      "properties": {
        "updatedAt": { "type": "string", "format": "date-time" },
        "sourceName": { "type": "string", "maxLength": 100 },
        "sourceUrl": { "type": "string", "format": "uri" },
        "tickers": {
          "type": "array",
          "items": { "$ref": "#/definitions/marketTicker" }
        },
        "commodities": {
          "type": "array",
          "items": { "$ref": "#/definitions/marketTicker" }
        }
      }
    },
    "marketTicker": {
      "type": "object",
      "required": ["symbol", "value", "changePct"],
      "additionalProperties": false,
      "properties": {
        "symbol": { "type": "string", "maxLength": 30 },
        "value": { "type": "string", "maxLength": 30 },
        "changePct": { "type": "number" }
      }
    },
    "weatherSnapshot": {
      "type": "object",
      "required": ["sourceName", "cities"],
      "additionalProperties": false,
      "properties": {
        "sourceName": { "type": "string", "maxLength": 100 },
        "sourceUrl": { "type": "string", "format": "uri" },
        "local": { "$ref": "#/definitions/weatherCell" },
        "cities": {
          "type": "array",
          "items": { "$ref": "#/definitions/weatherCell" }
        }
      }
    },
    "weatherCell": {
      "type": "object",
      "required": ["city", "tempC", "condition", "icon"],
      "additionalProperties": false,
      "properties": {
        "city": { "type": "string", "maxLength": 50 },
        "tempC": { "type": "number" },
        "condition": { "type": "string", "maxLength": 50 },
        "icon": { "type": "string", "enum": ["sun", "cloud", "rain", "snow", "partly"] }
      }
    },
    "transparencySource": {
      "type": "object",
      "required": ["name", "url", "articles"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "url": { "type": "string", "format": "uri" },
        "articles": { "type": "integer", "minimum": 0 }
      }
    },
    "generationMetadata": {
      "type": "object",
      "required": ["model", "sourcesCount", "storiesAnalyzed", "readingTimeMin"],
      "additionalProperties": false,
      "properties": {
        "model": { "type": "string", "maxLength": 100 },
        "sourcesCount": { "type": "integer", "minimum": 0 },
        "storiesAnalyzed": { "type": "integer", "minimum": 0 },
        "readingTimeMin": { "type": "integer", "minimum": 0 },
        "collectionStartedAt": { "type": "string", "format": "date-time" },
        "collectionFinishedAt": { "type": "string", "format": "date-time" }
      }
    },
    "footer": {
      "type": "object",
      "required": ["copyright"],
      "additionalProperties": false,
      "properties": {
        "copyright": { "type": "string", "maxLength": 200 },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/footerLink" }
        }
      }
    },
    "footerLink": {
      "type": "object",
      "required": ["label", "path"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "maxLength": 50 },
        "path": {
          "oneOf": [
            { "type": "string", "pattern": "^/" },
            { "type": "string", "format": "uri" }
          ]
        }
      }
    },
    "banner": {
      "type": "object",
      "required": ["id", "type", "message"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-zA-Z0-9_-]+$" },
        "type": { "type": "string", "enum": ["breaking", "notice", "correction"] },
        "message": { "type": "string", "maxLength": 200 },
        "link": {
          "type": "object",
          "required": ["label", "url"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "maxLength": 50 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
