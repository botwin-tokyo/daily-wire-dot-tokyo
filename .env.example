# Environment variables for news aggregation scripts in backend/scripts/
# Copy this file to .env and fill in the values for the sources you want to use.

# Ladder proxy for fetching publisher pages.
# See docker-compose.ladder.yml and backend/scripts/README.md.
LADDER_URL=http://localhost:8081

# Firecrawl API key (optional). Firecrawl is used for publishers that block
# Ladder. It works without a key from many IPs; if your IP is flagged, sign up
# for a free key at https://firecrawl.dev and paste it here.
FIRECRAWL_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare / D1 (only needed if you are publishing to Cloudflare Pages)
# ---------------------------------------------------------------------------

# Cloudflare account ID. Found on the right-hand side of any zone overview page
# in the Cloudflare dashboard, or under Account ID in the Workers/Pages section.
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token. Create one at https://dash.cloudflare.com/profile/api-tokens
# with the following permissions:
#   - Cloudflare Pages: Edit
#   - D1: Edit
#   - Account: Read (useful for listing databases)
CLOUDFLARE_API_TOKEN=

# D1 database ID. Create the database with:
#   wrangler d1 create morning-wire
# Then copy the UUID shown in the output here.
D1_DATABASE_ID=

# Optional: secret token used by /api/admin/* routes if you add admin endpoints.
ADMIN_TOKEN=
